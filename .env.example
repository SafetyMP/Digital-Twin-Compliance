# Core banking (CDC source)
CORE_BANKING_DB_URL=postgres://core:core@localhost:5433/core_banking?sslmode=disable

# State store
STATE_DB_URL=postgres://state:state@localhost:5434/twin_state?sslmode=disable

# Kafka
KAFKA_BROKERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# Default tenant (ADR-007 D1)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# State Service
STATE_SERVICE_HTTP_ADDR=:8080
STATE_SERVICE_SOURCE=state-service
STATE_SERVICE_URL=http://localhost:8080

# Debezium Connect
DEBEZIUM_CONNECT_URL=http://localhost:8083

# Redis (Phase 2)
REDIS_URL=redis://localhost:6380/0

# Alert Service (Phase 2)
ALERT_DB_URL=postgres://alert:alert@localhost:5435/alerts?sslmode=disable
ALERT_SERVICE_HTTP_ADDR=:8085
ALERT_SERVICE_URL=http://localhost:8085
ALERT_SERVICE_WS_PATH=/ws/alerts

# Flink (Phase 2)
FLINK_JOBMANAGER_URL=http://localhost:8082
FLINK_PARALLELISM=2

# Alert Console (Phase 2) — Next.js proxies /api/alerts → alert-service (no browser CORS).
# ALERT_SERVICE_URL is read server-side by route handlers; set in Compose for the console container.
ALERT_SERVICE_URL=http://localhost:8085
NEXT_PUBLIC_AUDIT_EXPLORER_URL=http://localhost:3002

# Host scripts only (smoke-test-phase2.py WebSocket probe — not used by alert-console UI)
ALERT_SERVICE_WS_URL=ws://localhost:8085/ws/alerts

# State Service CDC DLQ (Phase 1)
STATE_CDC_DLQ_TOPIC=domain.events.dlq

# Alert Service DLQ (Phase 2)
COMPLIANCE_ALERTS_DLQ_TOPIC=compliance.alerts.dlq

# Observability (Phase 2)
PROMETHEUS_URL=http://localhost:9090
KAFKA_EXPORTER_URL=http://localhost:9308

# CEP thresholds (Phase 2 dev defaults)
CEP_VELOCITY_MAX_PER_HOUR=50
CEP_EXPOSURE_LIMIT_EUR=10000000
CEP_LCR_MINIMUM=1.0
# Phase 3b: Flink CEP calls Decision Service (INT-R001/R002, BASEL-R001). Empty = inline thresholds only.
CEP_DECISION_SERVICE_URL=http://decision-service:8092

GRAFANA_URL=http://localhost:3030

# Grafana (Phase 2)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Phase 3 — immudb + audit + policy services
IMMUDB_HOST=localhost
IMMUDB_PORT=3322
IMMUDB_DATABASE=digitaltwin_audit
IMMUDB_USER=immudb
IMMUDB_PASSWORD=immudb
AUDIT_DB_URL=postgres://audit:audit@localhost:5436/audit?sslmode=disable
AUDIT_SERVICE_URL=http://localhost:8090
CEDAR_SERVICE_URL=http://localhost:8091
DECISION_SERVICE_URL=http://localhost:8092
AUDIT_EXPLORER_URL=http://localhost:3002
AUDIT_ARTIFACT_DIR=/data/audit-artifacts
KAFKA_AUDIT_PENDING_TOPIC=compliance.audit.pending
KAFKA_AUDIT_RECORDED_TOPIC=compliance.audit.recorded
CEDAR_POLICY_DIR=policies/cedar
ZEN_POLICY_DIR=policies/zen
